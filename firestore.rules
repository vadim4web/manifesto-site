rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isValidVoteDoc(userId) {
      return request.auth != null
        && userId == request.auth.uid
        && request.resource.data.keys().hasAll(['vote', 'userId', 'createdAt'])
        && request.resource.data.keys().hasOnly(['vote', 'userId', 'createdAt'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.vote in ['I', 'II', 'III', 'IV', 'V']
        && request.resource.data.createdAt == request.time;
    }

    match /manifestVotes/{userId} {
      allow read: if request.auth != null;

      allow create: if isValidVoteDoc(userId)
                    && !exists(/databases/$(database)/documents/manifestVotes/$(userId));

      allow update, delete: if false;
    }
  }
}
